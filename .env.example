# Supabase — Luxe Digital Dental Lab (tsngtzlwychbpagdinwj)
# Copia a .env y completa con las claves del dashboard:
# https://supabase.com/dashboard/project/tsngtzlwychbpagdinwj/settings/api

PUBLIC_SUPABASE_URL=https://tsngtzlwychbpagdinwj.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Solo servidor — obligatorio para crear clientes con acceso (Admin → Clientes)
# Nunca uses PUBLIC_* ni la expongas en el navegador
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP — Titan Mail (solo servidor, nunca PUBLIC_*)
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@luxedigitaldentallab.com
SMTP_PASSWORD=
SMTP_FROM=Luxe Digital Dental Lab <info@luxedigitaldentallab.com>

# POST /api/test-email: activo en desarrollo; en producción requiere "true"
ENABLE_TEST_EMAIL=false
